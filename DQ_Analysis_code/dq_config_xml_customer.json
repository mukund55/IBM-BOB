{
  "general": {
    "output_dir": "dq_output",
    "log_file": "dq_run.log",
    "encoding": "utf-8",
    "delimiter": ",",
    "normalize_column_names": true,
    "treat_blank_as_null": true,
    "trim_whitespace": true,
    "top_n_frequent_values": 5,
    "excel_output": true,
    "bad_records_prefix": "bad_records",
    "null_check_exclude_columns": ["CUSTOMER_GENDER"]
  },
  "input": {
    "xml": {
      "record_tag": "customer",
      "flatten_attributes": true,
      "include_root_text": false
    }
  },
  "keys": {
    "primary_keys": ["CUSTOMER_CUSTOMER_ID"]
  },
  "rules": {
    "mandatory_columns": ["CUSTOMER_CUSTOMER_ID", "CUSTOMER_EMAIL"],
    "mandatory_fields": ["CUSTOMER_CUSTOMER_ID", "CUSTOMER_FIRST_NAME", "CUSTOMER_LAST_NAME", "CUSTOMER_EMAIL"],
    "dtype_rules": {
      "CUSTOMER_CUSTOMER_ID": "numeric",
      "CUSTOMER_EMAIL": "string",
      "CUSTOMER_PHONE": "string",
      "CUSTOMER_SALARY": "numeric",
      "CUSTOMER_DOB": "date",
      "CUSTOMER_GENDER": "string",
      "CUSTOMER_FIRST_NAME": "string",
      "CUSTOMER_LAST_NAME": "string"
    },
    "range_rules": {
      "CUSTOMER_SALARY": {"min": 0, "max": 1000000}
    },
    "regex_rules": {
      "CUSTOMER_EMAIL": "^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$",
      "CUSTOMER_PHONE": "^[0-9]{10}$"
    },
    "allowed_values": {
      "CUSTOMER_GENDER": ["Male", "Female"]
    },
    "date_columns": {
      "CUSTOMER_DOB": {"format": "%Y-%m-%d", "min_date": "1900-01-01", "max_date": "2010-12-31"}
    },
    "email_columns": ["CUSTOMER_EMAIL"],
    "email_rules": {
      "CUSTOMER_EMAIL": {
        "pattern": "^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$",
        "allow_blank": false,
        "normalize_case": true
      }
    },
    "negative_not_allowed_columns": ["CUSTOMER_SALARY"],
    "special_character_rules": {
      "CUSTOMER_FIRST_NAME": "^[A-Za-z\\s.'-]*$",
      "CUSTOMER_LAST_NAME": "^[A-Za-z\\s.'-]*$"
    },
    "mixed_type_check_columns": ["CUSTOMER_CUSTOMER_ID", "CUSTOMER_SALARY", "CUSTOMER_DOB"],
    "mixed_type_rules": {
      "CUSTOMER_CUSTOMER_ID": {"expected_type": "numeric"},
      "CUSTOMER_SALARY": {"expected_type": "numeric"},
      "CUSTOMER_DOB": {"expected_type": "date", "format": "%Y-%m-%d"}
    }
  },
  "anomaly_detection": {
    "outlier_method": "iqr",
    "iqr_multiplier": 1.5,
    "zscore_threshold": 3.0,
    "max_unique_ratio_for_categorical_consistency": 0.95,
    "outlier_min_sample_size": 3,
    "outlier_columns": ["CUSTOMER_SALARY"],
    "outlier_column_overrides": {}
  },
  "scoring": {
    "weights": {
      "null_blank": 15,
      "duplicates": 10,
      "duplicate_primary_keys": 15,
      "outliers": 10,
      "mixed_types": 10,
      "invalid_dates": 10,
      "invalid_emails": 10,
      "negative_values": 10,
      "special_characters": 5,
      "datatype_violations": 10,
      "range_violations": 10,
      "pattern_violations": 10,
      "allowed_value_violations": 10,
      "missing_mandatory_columns": 20,
      "mandatory_field_violations": 15,
      "referential_integrity": 10,
      "business_rule_violations": 10
    }
  },
  "reference_integrity": {
    "enabled": false,
    "reference_file": "",
    "source_column": "",
    "reference_column": "",
    "reference_delimiter": ",",
    "reference_encoding": "utf-8"
  },
  "business_rules": []
}